{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "9d929d61-fbf7-4660-9a64-c9e0dc8ce965"
      }
    },
    "owner": "radialinformer790",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9d929d61-fbf7-4660-9a64-c9e0dc8ce965"
    },
    "plugins": [
      "expo-video",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Springfield Academy to access your camera to broadcast live sessions.",
          "microphonePermission": "Allow Springfield Academy to access your microphone for live audio.",
          "recordAudioPermission": "Allow Springfield Academy to record audio during your session."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Springfield Academy to save session recordings to your gallery.",
          "savePhotosPermission": "Allow Springfield Academy to save session recordings to your gallery.",
          "granularPermissions": [
            "audio",
            "photo",
            "video"
          ]
        }
      ],
      "expo-font"
    ]
  }
}
